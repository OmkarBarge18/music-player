{
  "name": "aura-music-player",
  "version": "1.0.0",
  "description": "Premium music player with advanced library scanning, streaming, and audio controls.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dist": "electron-builder",
    "cap:init": "cap init AuraPlayer com.omkarbarge.auraplayer --web-dir=web",
    "cap:sync": "cap sync",
    "cap:open": "cap open android"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "streaming"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "mime-types": "^2.1.35",
    "music-metadata": "^7.14.0",
    "node-id3": "^0.2.6",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.omkarbarge.auraplayer",
    "productName": "Aura Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!android/**/*",
      "!node_modules/*-builder/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
